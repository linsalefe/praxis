# === Práxis — variáveis de ambiente ===
# Copie para .env e ajuste. NUNCA commite .env.

# --- Banco ---
DATABASE_URL=postgresql+asyncpg://praxis_user:CHANGE_ME@127.0.0.1:5432/praxis

# --- Segurança ---
# 32 bytes base64 URL-safe (gere: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
PRAXIS_FIELD_KEY=CHANGE_ME_FERNET_KEY
# JWT (gere: `openssl rand -hex 32`)
PRAXIS_JWT_SECRET=CHANGE_ME_HEX32
PRAXIS_JWT_ALG=HS256
PRAXIS_JWT_TTL_MINUTES=60
# Nome da aplicação exibido no autenticador TOTP
PRAXIS_TOTP_ISSUER=Praxis by CENAT

# --- App ---
PRAXIS_ENV=dev
PRAXIS_BIND_HOST=127.0.0.1
PRAXIS_BIND_PORT=8040
PRAXIS_CORS_ORIGINS=http://127.0.0.1:3040,http://localhost:3040

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8040
