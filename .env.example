# === Práxis — variáveis de ambiente ===
# Copie para .env e ajuste. NUNCA commite .env.

# --- Banco ---
DATABASE_URL=postgresql+asyncpg://praxis_user:CHANGE_ME@127.0.0.1:5432/praxis

# --- Segurança ---
# 32 bytes base64 URL-safe (gere: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
PRAXIS_FIELD_KEY=CHANGE_ME_FERNET_KEY
# JWT (gere: `openssl rand -hex 32`)
PRAXIS_JWT_SECRET=CHANGE_ME_HEX32
PRAXIS_JWT_ALG=HS256
PRAXIS_JWT_TTL_MINUTES=60
# Nome da aplicação exibido no autenticador TOTP
PRAXIS_TOTP_ISSUER=Praxis by CENAT

# --- Sofia / RAG ---
# Chave da OpenAI (usada por Sofia: LLM + embeddings; e pelo Scribe: transcrição)
OPENAI_API_KEY=sk-CHANGE_ME
# Modelo de geração das respostas da Sofia
PRAXIS_LLM_MODEL=gpt-5.1-mini
# Modelo de embeddings (deve casar com PRAXIS_EMBED_DIM e a coluna pgvector)
PRAXIS_EMBED_MODEL=text-embedding-3-small
PRAXIS_EMBED_DIM=1536
# Nº de trechos recuperados por pergunta
PRAXIS_RAG_TOPK=6
# Similaridade mínima; abaixo disso a Sofia sinaliza "sem respaldo"
PRAXIS_RAG_SIM_MIN=0.28
# LGPD: se false (padrão), dados de paciente NÃO são enviados ao LLM
PRAXIS_SOFIA_SEND_PATIENT=false

# --- Scribe ---
# Backend de transcrição de áudio
PRAXIS_TRANSCRIBER=openai
# Modelo de transcrição
PRAXIS_TRANSC_MODEL=gpt-4o-mini-transcribe
# Diretório onde o áudio enviado é salvo
PRAXIS_SCRIBE_AUDIO_DIR=/opt/praxis/backend/uploads/audio
# Tamanho máximo do áudio (MB)
PRAXIS_SCRIBE_MAX_MB=25

# --- App ---
PRAXIS_ENV=dev
PRAXIS_BIND_HOST=127.0.0.1
PRAXIS_BIND_PORT=8040
PRAXIS_CORS_ORIGINS=http://127.0.0.1:3040,http://localhost:3040

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8040
