# Python / uv
.venv/
__pycache__/
*.pyc
*.pyo
.python-version
.uv-cache/

# Node / Next
node_modules/
.next/
out/
npm-debug.log*
.pnpm-debug.log*
.turbo/

# Env / segredos
.env
.env.local
.env.*.local
*.pem
*.key
.pgpass

# Backups de banco (contêm PII cifrada) — nunca versionar
backups/

# Uploads efêmeros (áudio do Scribe é apagado pós-transcrição)
backend/uploads/

# Caches do runtime do usuário `praxis` (HOME=/opt/praxis)
.npm/
.cache/
.config/
.local/

# IDE / SO
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Acervo — conteúdo (PDFs/DOCX/VTT, inclusive em subpastas) é grande e de terceiros.
# Mantemos apenas o manifest.toml versionado; o conteúdo fica fora do repo.
backend/acervo/*
!backend/acervo/manifest.toml

# Build
dist/
build/
